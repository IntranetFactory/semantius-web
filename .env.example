# OAuth2/OIDC Configuration
# Replace these values with your OAuth provider's settings

VITE_OAUTH_CLIENT_ID=your-client-id
VITE_OAUTH_AUTH_ENDPOINT=https://your-auth-server.com/oauth/authorize
VITE_OAUTH_TOKEN_ENDPOINT=https://your-auth-server.com/oauth/token
VITE_OAUTH_SCOPE=openid profile email
VITE_OAUTH_USERINFO_ENDPOINT=https://your-auth-server.com/oauth/userinfo
VITE_OAUTH_LOGOUT_ENDPOINT=https://your-auth-server.com/oauth/logout
VITE_OAUTH_LOGOUT_REDIRECT=http://localhost:5173/login


# Optional: Redirect URI use current url per default
VITE_OAUTH_REDIRECT_URI=

# Optional: Audience parameter (required for Auth0 and some other providers)
# For Auth0: This should be your API identifier (e.g., https://your-api-identifier)
# Leave empty if your OAuth provider doesn't require an audience parameter
VITE_OAUTH_AUDIENCE=

# Control Plane (optional)
# When set, tenant config is fetched from this URL at startup.
# The tenant name is derived from the leftmost subdomain of the current URL.
# The response's postgrest_url overrides VITE_API_BASE_URL.
VITE_CONTROL_PLANE_URL=
# When set, uses this value as the tenant/org name instead of extracting it from the subdomain.
VITE_CONTROL_PLANE_ORG=

# API Configuration (REQUIRED unless provided by control plane)
# Base URL for PostgREST API (e.g., Supabase or Neon Data API)
VITE_API_BASE_URL=https://your-postgrest-api.com

# Optional API Configuration
# API_TYPE: Leave empty for generic PostgREST, or set to "supabase" for Supabase-specific features
VITE_API_TYPE=

# VITE_SUPABASE_APIKEY: Required when VITE_API_TYPE=supabase
# This is the anon/public API key (Publishable key) from your Supabase project settings
VITE_SUPABASE_APIKEY=



