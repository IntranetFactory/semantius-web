# Caddy config for the runtime-configurable SPA image. Replaces the old
# nginx.conf. Serves the Vite build as a single-page app AND (optionally)
# reverse-proxies /api and /api-docs to sibling containers so the whole stack
# is reachable through this ONE exposed endpoint.
#
# Env placeholders ({$VAR:default}) are resolved by Caddy at container start:
#   SITE_ADDRESS  - listen address. Default ":80" (plain HTTP, TLS terminated by
#                   an outer proxy). Set to a domain (e.g. app.example.com) to
#                   turn on Caddy's automatic HTTPS (needs ports 80+443 and a
#                   persistent /data volume for the certs).
#   API_UPSTREAM  - upstream for /api/*      (default postgrest:3000)
#   DOCS_UPSTREAM - upstream for /api-docs/* (default scalar:8080)
#
# Unlike nginx, Caddy re-resolves upstream DNS per request, so a postgrest/scalar
# container that starts later or is recreated just works — no startup ordering.
# When those containers are absent the proxy routes simply 502; the SPA still
# serves. The routes are opt-in: the SPA only uses /api when VITE_API_BASE_URL
# is set to "/api" (it defaults to an absolute external URL).

{$SITE_ADDRESS::80} {
	encode zstd gzip

	# Reverse-proxy to sibling containers. handle_path strips the matched prefix,
	# so PostgREST sees /customers (not /api/customers) and Scalar sees / .
	handle_path /api/* {
		reverse_proxy {$API_UPSTREAM:postgrest:3000}
	}
	handle_path /api-docs/* {
		reverse_proxy {$DOCS_UPSTREAM:scalar:8080}
	}

	# Everything else: serve the static SPA with client-side-routing fallback.
	handle {
		root * /srv

		# Runtime config + entry HTML must never be cached — config.js is
		# regenerated per container start and index.html references hashed assets.
		@nocache path /config.js /index.html
		header @nocache Cache-Control "no-store, must-revalidate"

		# Vite emits content-hashed files under /assets/ — safe to cache forever.
		@assets path /assets/*
		header @assets Cache-Control "public, max-age=31536000, immutable"

		# SPA fallback: unknown paths (client-side routes) serve index.html.
		try_files {path} /index.html
		file_server
	}
}
